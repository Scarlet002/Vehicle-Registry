<Window x:Class="VehicleRegistryWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestr pojazdów" Height="600" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="300" 
                     ToolTip="Szukaj w dowolnej kolumnie" Margin="0,0,10,0"/>
            <Button Content="Szukaj" Width="80" Command="{Binding SearchCommand}"/>
            <Button Content="Wszystkie" Width="80" Command="{Binding ShowAllCommand}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Rejestruj pojazd" Width="130" Command="{Binding AddCommand}"/>
            <Button Content="Wyrejestruj" Width="100" Command="{Binding UnregisterCommand}"/>
            <Button Content="Dodaj przegląd" Width="120" Command="{Binding InspectionCommand}"/>
            <Button Content="Ubezpieczenie" Width="100" Command="{Binding InsuranceCommand}"/>
            <Button Content="Historia" Width="80" Command="{Binding HistoryCommand}"/>
            <Button Content="Usuń" Width="80" Command="{Binding DeleteCommand}"/>
            <Button Content="Odśwież" Width="80" Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="VehiclesGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="False" 
                  SelectionMode="Single"
                  ItemsSource="{Binding Vehicles}"
                  SelectedItem="{Binding SelectedVehicle, Mode=TwoWay}"
                  CellEditEnding="VehiclesGrid_CellEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Nr rejestracyjny" Binding="{Binding RegistrationNumber}" Width="120"/>
                <DataGridTextColumn Header="VIN" Binding="{Binding Vin}" Width="100"/>
                <DataGridTextColumn Header="Marka" Binding="{Binding Brand}" Width="90"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="90"/>
                <DataGridTextColumn Header="Rok" Binding="{Binding ProductionYear}" Width="60"/>
                <DataGridTextColumn Header="Przebieg" Binding="{Binding Mileage}" Width="70"/>
                <DataGridTextColumn Header="Właściciel" Binding="{Binding Owner}" Width="120"/>
                <DataGridTextColumn Header="Przegląd do" Binding="{Binding InspectionValidUntil, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                <DataGridTextColumn Header="Ubezpieczenie do" Binding="{Binding InsuranceValidUntil, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                <DataGridTemplateColumn Header="Zarejestrowany" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsRegistered}"
                                      Command="{Binding DataContext.ToggleRegistrationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      CommandParameter="{Binding}"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>