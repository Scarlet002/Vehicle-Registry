<Window x:Class="VehicleRegistryWPF.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historia pojazdu" Height="400" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleLabel" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
        <DataGrid Grid.Row="1" x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data" Binding="{Binding EventDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="120"/>
                <DataGridTextColumn Header="Typ zdarzenia" Binding="{Binding EventType}" Width="150"/>
                <DataGridTextColumn Header="Ważne do" Binding="{Binding ValidUntil, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                <DataGridTextColumn Header="Informacje" Binding="{Binding AdditionalInfo}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>