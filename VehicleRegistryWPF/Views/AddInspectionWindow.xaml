<Window x:Class="VehicleRegistryWPF.Views.AddInspectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj przegląd techniczny" Height="220" Width="350" 
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Numer rejestracyjny:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Margin="5" FontWeight="Bold"
                   Text="{Binding RegistrationNumber}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Data ważności:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="1" Grid.Column="1" 
                    SelectedDate="{Binding ValidUntil, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="OK" Width="80" Margin="5" Command="{Binding SaveCommand}"/>
            <Button Content="Anuluj" Width="80" Margin="5" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>