<Window x:Class="VehicleRegistryWPF.Views.AddVehicleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestracja pojazdu" Height="520" Width="450" 
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Numer rejestracyjny:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" 
                 Text="{Binding NewVehicle.RegistrationNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="VIN (opcjonalnie):" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" 
                 Text="{Binding NewVehicle.Vin, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Marka:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" 
                 Text="{Binding NewVehicle.Brand, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" 
                 Text="{Binding NewVehicle.Model, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Rok produkcji:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" 
                 Text="{Binding NewVehicle.ProductionYear, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Przebieg (km):" VerticalAlignment="Center"/>
        <TextBox Grid.Row="5" Grid.Column="1" 
                 Text="{Binding NewVehicle.Mileage, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Właściciel:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="6" Grid.Column="1" 
                 Text="{Binding NewVehicle.Owner, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Ubezpieczenie do:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="7" Grid.Column="1" 
                    SelectedDate="{Binding NewVehicle.InsuranceValidUntil, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="OK" Width="80" Margin="5" Command="{Binding SaveCommand}"/>
            <Button Content="Anuluj" Width="80" Margin="5" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>