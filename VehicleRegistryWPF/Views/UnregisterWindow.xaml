<Window x:Class="VehicleRegistryWPF.Views.UnregisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wyrejestrowanie pojazdu" Height="150" Width="350" 
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <TextBlock Text="Czy na pewno wyrejestrować pojazd?" Margin="0,0,0,10"/>
        <TextBlock Text="{Binding RegistrationNumber}" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Tak" Width="60" Margin="5" Command="{Binding ConfirmCommand}"/>
            <Button Content="Nie" Width="60" Margin="5" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>